# ClaudeFairy V2 — 环境变量模板
# 复制为 .env 后填入真实值（.env 已在 .gitignore，绝对不要提交真实密钥）

# ---- Telegram（必填）----
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 允许操作 Bot 的 Telegram chat_id 白名单（逗号分隔）
# 使用 @userinfobot 获取你的 chat_id
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ---- Anthropic / Claude（可选）----
# ClaudeFairy 通过本地 `claude` CLI 的登录态调用 Claude，无需 API Key。
# 只要你已经执行过 `claude login`，这里可以不填。
# 仅在需要强制覆盖 CLI 认证时填入。
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- GitHub Token（可选，提升 Scout 的 API 限额）----
# 从 https://github.com/settings/tokens 获取（只需 public_repo read 权限）
# GITHUB_TOKEN=ghp_your_token_here

# ---- 可选：代理设置 ----
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
