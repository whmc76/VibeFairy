# VibeFairy — 配置模板（不含任何真实密钥）
# 复制为 vibefairy.toml 后填入真实配置（vibefairy.toml 已在 .gitignore）
# 所有密钥必须通过 .env 文件或环境变量传入，不得写在此文件中

[daemon]
# 日志级别: debug / info / warning / error
log_level = "info"
# 日志文件目录（相对路径）
log_dir = "data/logs"
# 数据库路径（相对路径）
db_path = "data/vibefairy.db"
# 每轮 Scout 间隔（秒）
scout_interval_secs = 3600
# 每日日报时间（24h 格式，本地时区）
daily_report_time = "09:00"

[targets]
# 管理的项目列表，每个条目是一个 [[targets.projects]] 块
# path 建议使用相对路径（相对于 vibefairy 启动目录）或绝对路径
[[targets.projects]]
name = "my-project"
path = "../my-project"
description = "我的项目描述"
# 是否允许写操作（需要额外的 /approve 审批）
allow_write = true
# 是否作为主要分析目标
primary = true

[budget]
# 每日 token 上限（0 = 无限制）
daily_token_limit = 500_000
# 单任务 token 上限
per_task_token_limit = 50_000
# 来源抓取 QPS
source_fetch_qps = 2
# 429/503 自动退避
source_fetch_backoff = true
# 超限降级模式: "report_only" / "pause" / "alert_only"
over_budget_mode = "report_only"

[scout]
# 最低星标数（GitHub Search 结果）
min_stars_search = 100
# 最低星标数（GitHub Trending）
min_stars_trending = 50
# L2 快评最低分数阈值（0-10）
l2_min_score = 6.0
# L3 深度分析最低分数阈值（触发立即通知）
l3_notify_score = 8.0
# 感兴趣的语言
languages = ["rust", "python", "typescript", "go"]
# 感兴趣的关键词（用于 title/description 过滤）
keywords = [
    "agent", "llm", "ai", "async", "tokio",
    "orchestrator", "workflow", "scheduler",
]

[retry]
max_retries = 3
backoff_base_secs = 30
backoff_max_secs = 300
# 可重试的错误类型
transient_errors = ["rate_limit", "timeout", "connection_error"]

[lock]
# 目标锁 TTL（分钟）
ttl_minutes = 60

[approval]
# 审批 TTL（分钟）
default_ttl_minutes = 30

[triage]
# 分拣最大重试次数（超出则标记为 failed）
max_retries = 3
# 分拣使用的模型（只读操作，复用 Claude Code SDK）
model = "claude-sonnet-4-6"
# 每次分拣 Claude 调用超时（秒）
timeout_secs = 60
# 调度器扫描未处理任务的间隔（秒）
queue_scan_interval_secs = 60

[notification]
# 静默时段起始（本地时间 HH:MM）。静默时段内仅 P0 任务会立即通知。
quiet_hours_start = "23:00"
# 静默时段结束（本地时间 HH:MM）
quiet_hours_end = "08:00"
# 注: 日报固定时间发送，不受静默时段影响

[auth]
# OAuth 登录超时（秒）。超时后 /login 流程将中止。
login_timeout_secs = 300
# 认证状态缓存时间（秒）。/auth 命令在此期间内不重复调用 CLI。
status_cache_secs = 60

[features]
# 是否启用 Scout 自动发现流程（GitHub 趋势分析）
# 关闭后，/scout 命令将不可用，定时任务不会运行
scout_enabled = false
# 是否启用自动分诊模式（消息 → 分类 → 任务/问答/笔记）
# false（默认）= 会话模式：消息直接发往当前活跃的 AI 会话
# true = 分诊模式：恢复旧行为，消息自动分类处理
triage_auto = false

[session]
# 默认 AI 后端: "claude" 或 "codex"
default_backend = "claude"
# 默认模型（留空则使用后端的内置默认值）
default_model = "claude-sonnet-4-6"
# 流式输出编辑消息的最小间隔（秒），避免触发 Telegram 限速
streaming_edit_interval_secs = 2.0
# 单条消息最大长度（超出后分段发送）
max_message_length = 4000
